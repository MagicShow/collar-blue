# ─── ContractorHub — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.

# ─── Core ────────────────────────────────────────────────────────────────────
PORT=3001
CLIENT_URL=http://localhost:5173

# ─── OpenAI (required for real AI features) ──────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# Use a dedicated key scoped to Chat Completions + Image Generation only.
OPENAI_API_KEY=sk-...

# ─── Email (SMTP — required before launch) ───────────────────────────────────
# Option A: Gmail SMTP (easy for dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your@gmail.com

# Option B: SendGrid (production)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG.your-sendgrid-api-key
# SMTP_FROM=your@domain.com

# ─── Image Upload (required before launch) ───────────────────────────────────
# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...
# Use unsigned upload preset for simplicity:
CLOUDINARY_UPLOAD_PRESET=collar-blue-unsigned

# ─── Database (Phase 2 — Neon PostgreSQL + Prisma) ───────────────────────────
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/collar_blue?sslmode=require
